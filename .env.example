# 复制为 .env.local 后填写（.env.local 不会被 git 跟踪）

# Gemini API（可选）
GEMINI_API_KEY=

# 智谱 AI（可选，推荐国内使用）
ZHIPU_API_KEY=
# ZHIPU_DEFAULT_MODEL=glm-4-flash
# ZHIPU_VISION_MODEL=glm-4.6v
# AI_OCR_USE_GEMINI=1
# GEMINI_HTTP_PROXY=http://127.0.0.1:7890
# AI_OCR_PROVIDER=gemini
# AI_DEFAULT_PROVIDER=zhipu

# MinerU 错题图片 OCR（对齐桌面端 MinerU VLM：vlm + 表格 + 公式 + 中文）
# MINERU_API_URL=http://127.0.0.1:8000
# MINERU_API_MODE=local
# MINERU_BACKEND=vlm
# MINERU_API_KEY=
# MINERU_LANG=ch
# MINERU_PARSE_METHOD=auto
# MINERU_OCR_ENABLED=1
# MINERU_OCR_FALLBACK_VISION=0
# AI_OCR_LLM_CORRECT=0

# 题干 OCR 前去除红/蓝笔迹（颜色通道掩膜，默认开启；设 0 关闭）
# EXAM_INK_PREPROCESS=0
# 手写黑栏：从 OCR 噪声自动回收短答（默认关闭，易误产 3N/5N 碎片墙；需时设 1）
# AI_HW_RECOVER_FROM_NOISE=0
# 分色手写：净化图提黑笔 + 红墨掩膜提红笔（默认开启；设 0 回退旧版双色合图）
# AI_HANDWRITTEN_SPLIT_COLOR=1
# 手写识别专用视觉模型（推荐 glm-4.6v，避免 glm-4v-plus 余额问题）
# ZHIPU_HANDWRITTEN_MODEL=glm-4.6v
# AI_HANDWRITTEN_ANSWER=0

# 可选：AI Key 加密专用密钥（默认使用 JWT_SECRET 派生）
# AI_KEY_ENCRYPTION_SECRET=

# 服务端口（生产模式前后端同端口；默认 8790，避免与其他项目 8787 冲突）
PORT=8790
# API_PORT=8790

# 开发前端端口（Vite，默认 3010，避免与其他项目 3000 冲突）
# VITE_DEV_PORT=3010
# DEV_WEB_PORT=3010

# 监听地址
HOST=0.0.0.0

# 跨域来源（开发模式，逗号分隔；局域网 IP 默认自动放行）
CORS_ORIGIN=http://localhost:3010,http://localhost:5180
# CORS_LAN=0

# 首次启动自动创建管理员（数据库为空时）
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=

# 数据库路径（默认 data/zhishitree.db）
# DATABASE_PATH=

# 生产环境：设为 0 可在 HTTP 下正常使用登录 Cookie
# COOKIE_SECURE=0

# 设为 0 可禁用 Express 托管 dist 静态文件
# SERVE_STATIC=0
